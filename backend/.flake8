[flake8]
max-line-length = 100
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    migrations,
    *.pyc,
    *.pyo,
    *.pyd,
    .pytest_cache,
    .coverage,
    htmlcov,
    build,
    dist,
    *.egg-info
ignore = 
    E203,
    W503,
    E501,
    F401,
    F403,
    F405
per-file-ignores =
    __init__.py:F401
    migrations/*:E501
    tests/*:E501
    */tests/*:E501 