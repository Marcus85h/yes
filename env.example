# 应用配置
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,api.videodating.com

# 数据库配置
DB_NAME=video_dating
DB_USER=videodating
DB_PASSWORD=your-database-password
DB_HOST=postgres
DB_PORT=5432

# Redis配置
REDIS_URL=redis://:your-redis-password@redis:6379/0
REDIS_PASSWORD=your-redis-password

# AWS S3配置
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=video-dating-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=cdn.videodating.com

# 第三方服务配置
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
GRAFANA_PASSWORD=your-grafana-password

# WebRTC配置
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_SERVERS=turn:turn.videodating.com:3478?username=user&credential=pass

# 支付配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_API_KEY=your-wechat-api-key

# 短信配置
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=your-sms-access-key
SMS_ACCESS_KEY_SECRET=your-sms-secret-key
SMS_SIGN_NAME=视频交友
SMS_TEMPLATE_CODE=SMS_123456789

# 推送配置
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=your-fcm-sender-id

# 第三方登录配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
QQ_APP_ID=your-qq-app-id
QQ_APP_KEY=your-qq-app-key

# 邮件配置
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True

# 安全配置
CORS_ALLOWED_ORIGINS=https://videodating.com,https://www.videodating.com
CSRF_TRUSTED_ORIGINS=https://videodating.com,https://www.videodating.com

# 监控配置
PROMETHEUS_ENABLED=True
GRAFANA_ENABLED=True
ELASTICSEARCH_ENABLED=True

# 功能开关
ENABLE_VIDEO_CALL=True
ENABLE_AUDIO_CALL=True
ENABLE_GIFT_SYSTEM=True
ENABLE_PAYMENT=True
ENABLE_PUSH_NOTIFICATION=True
ENABLE_THIRD_PARTY_LOGIN=True
ENABLE_SCREEN_RECORDING=False

# 性能配置
CELERY_WORKERS=4
CELERY_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_TIME_LIMIT=3600

# 缓存配置
CACHE_TTL=3600
SESSION_COOKIE_AGE=86400
PASSWORD_RESET_TIMEOUT=3600

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,gif,mp4,mov,avi,mp3,wav,m4a

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/video_dating/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5 